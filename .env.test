# Committed, NON-SECRET test configuration.
# Loaded by scripts/test.sh, which starts a throwaway Postgres on TEST_DB_PORT.
# CI does not read this file — the CI workflow supplies its own Postgres service
# and DATABASE_URL. Never put real secrets here.
DATABASE_URL=postgresql://test:test@localhost:5433/subly_test
AUTH_SECRET=test-secret-not-for-production
ADMIN_EMAIL=test-admin@example.com
ADMIN_PASSWORD=test-admin-password
