# Copy to .env and fill in real values for local development.
# All four are required and enforced at runtime by lib/env.ts.
#
# For local dev this project runs Postgres in Docker on host port 5434
# (see README). For running the test suite you do NOT need to set these —
# use `npm run test:local`, which provisions its own throwaway database.
DATABASE_URL=postgresql://subly:subly@localhost:5434/subly
AUTH_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
